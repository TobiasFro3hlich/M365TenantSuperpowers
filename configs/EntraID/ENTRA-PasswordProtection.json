{
    "metadata": {
        "id": "ENTRA-007",
        "name": "Password Protection - Custom Banned List",
        "description": "Enables custom banned password list and configures smart lockout settings. Prevents users from using common weak passwords and org-specific terms.",
        "severity": "Critical",
        "category": "PasswordProtection",
        "tags": ["password", "banned-passwords", "smart-lockout", "security"],
        "microsoftReference": "https://learn.microsoft.com/entra/identity/authentication/concept-password-ban-bad",
        "compliance": { "cisaScuba": ["MS.AAD.6.1v1"], "cisV6": ["1.3.1", "5.2.3.2", "5.2.3.3"], "microsoftPreset": "N/A" }
    },
    "settings": {
        "enableBannedPasswordCheck": true,
        "bannedPasswordList": [
            "company",
            "company123",
            "welcome",
            "welcome1",
            "password",
            "p@ssword",
            "summer2024",
            "winter2024",
            "qwerty123"
        ],
        "enableBannedPasswordCheckOnPremises": true,
        "bannedPasswordCheckOnPremisesMode": "Enforce",
        "lockoutThreshold": 10,
        "lockoutDurationInSeconds": 60
    },
    "parameters": {
        "customBannedWords": {
            "description": "Additional banned words specific to the customer (company name, product names, etc.)",
            "required": false,
            "type": "stringArray"
        }
    }
}
