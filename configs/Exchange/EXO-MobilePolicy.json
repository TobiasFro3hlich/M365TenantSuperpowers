{
    "metadata": {
        "id": "EXO-007",
        "name": "Mobile Device Policy - Secure Baseline",
        "description": "Configures mobile device mailbox policy requiring encryption and password, with device wipe capability after failed attempts.",
        "severity": "High",
        "category": "MobilePolicy",
        "tags": ["mobile", "activesync", "device-policy", "baseline"],
        "microsoftReference": "https://learn.microsoft.com/powershell/module/exchange/set-mobiledevicemailboxpolicy",
        "compliance": {
            "cisaScuba": [],
            "cisV6": [],
            "microsoftPreset": "Best practice (mobile security)"
        }
    },
    "settings": {
        "policyName": "Default",
        "policy": {
            "PasswordEnabled": true,
            "AlphanumericPasswordRequired": false,
            "MinPasswordLength": 6,
            "MaxPasswordFailedAttempts": 10,
            "AllowSimplePassword": false,
            "PasswordExpiration": "Unlimited",
            "RequireDeviceEncryption": true,
            "AllowNonProvisionableDevices": true,
            "MaxInactivityTimeLock": "00:15:00",
            "DeviceEncryptionEnabled": true
        }
    },
    "parameters": {}
}
